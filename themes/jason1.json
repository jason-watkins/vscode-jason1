    "semanticTokenColors": {
        "newOperator": "#EDB32D",
        "stringLiteral": "#C0C340",
        "customLiteral": "#fbfbe7",
        "numberLiteral": "#CE3C2B"
    },
    "tokenColors": [
        {
            "scope": [
                "meta.embedded",
                "source.groovy.embedded",
                "string meta.image.inline.markdown",
                "variable.legacy.builtin.python"
            ],
            "settings": {
                "foreground": "#fbfbe7"
            }
        },
        {
            "scope": "emphasis",
            "settings": {
                "fontStyle": "italic"
            }
        },
        {
            "scope": "strong",
            "settings": {
                "fontStyle": "bold"
            }
        },
        {
            "scope": "comment",
            "settings": {
                "foreground": "#83B172"
            }
        },
        {
            "scope": [
                "string",
                "meta.embedded.assembly",
                "string.tag",
                "string.value"
            ],
            "settings": {
                "foreground": "#C0C340"
            }
        },
        {
            "scope": [
                "entity.name.user-defined-literal.string",
                "string.unquoted.plain.out"
            ],
            "settings": {
                "foreground": "#8E901D"
            }
        },
        {
            "scope": "markup.inline.raw",
            "settings": {
                "foreground": "#C0C340"
            }
        },
        {
            "scope": "meta.preprocessor.string",
            "settings": {
                "foreground": "#C0C340"
            }
        },
        {
            "scope": [
                "constant.numeric",
                "keyword.operator.plus.exponent",
                "keyword.operator.minus.exponent"
            ],
            "settings": {
                "foreground": "#CE3C2B"
            }
        },
        {
            "scope": [
                "constant.language",
                "keyword.other.unit",
                "support.constant.json",
                "entity.name.user-defined-literal.number",
                "entity.name.user-defined-literal",
                "storage.type.number"
            ],
            "settings": {
                "foreground": "#CE3C2B"
            }
        },
        {
            "scope": "meta.preprocessor.numeric",
            "settings": {
                "foreground": "#CE3C2B"
            }
        },
        {
            "scope": "constant.sha.git-rebase",
            "settings": {
                "foreground": "#CE3C2B"
            }
        },
        {
            "scope": [
                "constant.other.placeholder",
                "constant.character",
                "constant.character.escape"
            ],
            "settings": {
                "foreground": "#AF8421",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "invalid",
            "settings": {
                "foreground": "#CE3C2B"
            }
        },
        {
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.operator",
                "keyword.operator.cast",
                "keyword.operator.delete",
                "keyword.operator.expression",
                "keyword.operator.instanceof",
                "keyword.operator.instanceof.java",
                "keyword.operator.member",
                "keyword.operator.new",
                "keyword.operator.new.cpp",
                "keyword.operator.sizeof",
                "keyword.operator.alignof",
                "keyword.operator.typeid",
                "keyword.operator.alignas",
                "keyword.operator.wordlike",
                "keyword.operator.noexcept",
                "keyword.operator.logical.python",
                "keyword.other.directive.using",
                "keyword.other.using",
                "keyword.other.operator",
                "entity.name.operator",
                "entity.other.attribute.noreturn",
                "storage",
                "storage.type",
                "storage.modifier",
                "storage.type.cs",
                "variable.language.this.cs"
            ],
            "settings": {
                "foreground": "#EDB32D"
            }
        },
        {
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.name.class.template",
                "entity.name.class.reference",
                "entity.name.class.value",
                "entity.other.inherited-class",
                "entity.other.attribute",
                "meta.type.cast.expr",
                "meta.type.new.expr",
                "punctuation.separator.namespace.ruby",
                "support.class",
                "support.type",
                "support.type.property-name",
                "support.type.vendored.property-name",
                "support.constant.math",
                "support.constant.dom",
                "storage.type.generic.cs",
                "storage.type.modifier.cs",
                "storage.type.variable.cs",
                "storage.type.annotation.java",
                "storage.type.generic.java",
                "storage.type.java",
                "storage.type.object.array.java",
                "storage.type.primitive.java",
                "storage.type.primitive.array.java",
                "storage.type.token.java",
                "storage.type.groovy",
                "storage.type.annotation.groovy",
                "storage.type.parameters.groovy",
                "storage.type.generic.groovy",
                "storage.type.object.array.groovy",
                "storage.type.primitive.array.groovy",
                "storage.type.primitive.groovy",
                "storage.type.numeric.go",
                "storage.type.byte.go",
                "storage.type.boolean.go",
                "storage.type.string.go",
                "storage.type.uintptr.go",
                "storage.type.error.go",
                "storage.type.rune.go",
                "entity.other.attribute-name.class.css",
                "entity.name.tag.css",
                "entity.name.tag.less"
            ],
            "settings": {
                "foreground": "#A1C3C8"
            }
        },
        {
            "scope": [
                "entity.name.function",
                "entity.name.function.template",
                "entity.name.function.member",
                "entity.name.function.member.static",
                "entity.name.function.operator",
                "entity.name.class.generic",
                "entity.name.label",
                "entity.name.namespace",
                "entity.name.scope-resolution",
                "entity.name.type.namespace",
                "entity.name.operator.custom-literal",
                "meta.object-literal.key",
                "meta.structure.dictionary.key.python",
                "meta.template.expression",
                "source.powershell variable.other.member",
                "support.function",
                "support.constant.handlebars",
                "support.function.git-rebase",
                "variable",
                "variable.language",
                "variable.other.constant",
                "variable.other.enummember",
                "variable.other.event",
                "variable.other.global",
                "variable.other.local",
                "variable.other.member",
                "variable.other.member.static",
                "variable.other.property",
                "variable.parameter",
                "variable.other.member.powershell",
                "variable.css",
                "meta.definition.variable.name",
                "support.variable",
                "entity.name.variable",
                "storage.modifier.import.java",
                "variable.language.wildcard.java",
                "storage.modifier.package.java",
                "source.css variable",
                "source.coffee.embedded"
            ],
            "settings": {
                "foreground": "#fbfbe7"
            }
        },
        {
            "scope": [
                "entity.name.function.preprocessor",
                "meta.preprocessor"
            ],
            "settings": {
                "foreground": "#AAA1B9"
            }
        },
        {
            "scope": [
                "entity.name.tag",
                "entity.other.attribute-name",
                "punctuation.definition.template-expression.begin",
                "punctuation.definition.template-expression.end",
                "punctuation.section.embedded",
                "punctuation.section.embedded.begin.php",
                "punctuation.section.embedded.end.php"
